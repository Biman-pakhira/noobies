generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VideoStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum VideoResolution {
  RES_360P
  RES_480P
  RES_720P
  RES_1080P
}

enum InteractionType {
  LIKE
  DISLIKE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  username     String     @unique
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  bio          String?
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  videos            Video[]
  comments          Comment[]
  watchHistory      WatchHistory[]
  playlists         Playlist[]
  interactions      VideoInteraction[]
  reports           Report[]
  refreshTokens     RefreshToken[]
}

model Video {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  uploaderId  String      @db.ObjectId
  uploader    User        @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  status      VideoStatus @default(UPLOADED)
  duration    Int
  views       Int         @default(0)
  likes       Int         @default(0)
  dislikes    Int         @default(0)
  isPublic    Boolean     @default(true)
  tagIds      String[]    @db.ObjectId
  categoryId  String?     @db.ObjectId
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  videoFiles     VideoFile[]
  thumbnails     Thumbnail[]
  comments       Comment[]
  watchHistory   WatchHistory[]
  playlistVideos PlaylistVideo[]
  interactions   VideoInteraction[]
  reports        Report[]

  @@index([uploaderId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model Tag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

model VideoFile {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  videoId    String          @db.ObjectId
  video      Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  resolution VideoResolution
  fileUrl    String
  format     String          @default("hls")
  size       Int
  bitrate    Int
  createdAt  DateTime        @default(now())

  @@index([videoId])
}

model Thumbnail {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  url       String
  timestamp Int
  createdAt DateTime @default(now())

  @@index([videoId])
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now())

  videos Video[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@index([userId])
}

model WatchHistory {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId         String   @db.ObjectId
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  progressSeconds Int      @default(0)
  watchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([videoId])
}

model Playlist {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  thumbnailUrl String?
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos PlaylistVideo[]

  @@index([userId])
}

model PlaylistVideo {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  playlistId String   @db.ObjectId
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoId    String   @db.ObjectId
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  position   Int
  addedAt    DateTime @default(now())

  @@index([playlistId])
  @@index([videoId])
}

model VideoInteraction {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId   String          @db.ObjectId
  video     Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type      InteractionType
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([videoId])
}

model Report {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  videoId    String       @db.ObjectId
  video      Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId     String       @db.ObjectId
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  status     ReportStatus @default(PENDING)
  notes      String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@index([videoId])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
