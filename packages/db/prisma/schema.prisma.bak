// This is your Prisma schema file for MongoDB
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============= ENUMS =============

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VideoStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum VideoResolution {
  RES_360P
  RES_480P
  RES_720P
  RES_1080P
}

enum InteractionType {
  LIKE
  DISLIKE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

// ============= CORE MODELS =============

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  username  String     @unique
  email     String     @unique
  passwordHash String
  role      UserRole   @default(USER)
  bio       String?
  avatarUrl String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  videos            Video[]
  comments          Comment[]
  watchHistory      WatchHistory[]
  playlists         Playlist[]
  interactions      VideoInteraction[]
  reports           Report[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([username])
}

model Video {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  uploaderId  String      @db.ObjectId
  uploader    User        @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  status      VideoStatus @default(UPLOADED)
  duration    Int         // in seconds
  views       Int         @default(0)
  likes       Int         @default(0)
  dislikes    Int         @default(0)
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  videoFiles      VideoFile[]
  thumbnails      Thumbnail[]
  tags            Tag[]
  categoryId      String?    @db.ObjectId
  category        Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments        Comment[]
  watchHistory    WatchHistory[]
  playlistVideos  PlaylistVideo[]
  interactions    VideoInteraction[]
  reports         Report[]

  @@index([uploaderId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model VideoFile {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  videoId     String          @db.ObjectId
  video       Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  resolution  VideoResolution
  fileUrl     String
  format      String          @default("hls") // "hls" or "mp4"
  size        Int             // in bytes
  bitrate     Int             // in kbps
  createdAt   DateTime        @default(now())

  @@index([videoId, resolution])
  @@index([videoId])
}

model Thumbnail {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  url       String
  timestamp Int      // seconds into the video
  createdAt DateTime @default(now())

  @@index([videoId])
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now())

  // Relations
  videos Video[]
}

model Tag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  // Relations
  videos Video[]

  @@index([slug])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@index([userId])
  @@index([createdAt])
}

model WatchHistory {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId          String   @db.ObjectId
  video            Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  progressSeconds  Int      @default(0) // last watched position
  watchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@index([watchedAt])
}

model Playlist {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  thumbnailUrl String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  videos PlaylistVideo[]

  @@index([userId])
  @@index([createdAt])
}

model PlaylistVideo {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  playlistId String   @db.ObjectId
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoId    String   @db.ObjectId
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  position   Int      // order in playlist
  addedAt    DateTime @default(now())

  @@index([playlistId, videoId])
  @@index([playlistId])
  @@index([videoId])
}

model VideoInteraction {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId   String          @db.ObjectId
  video     Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type      InteractionType
  createdAt DateTime        @default(now())

  @@index([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@index([type])
}

model Report {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String       @db.ObjectId
  video     Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  status    ReportStatus @default(PENDING)
  notes     String?
  createdAt DateTime     @default(now())
  resolvedAt DateTime?

  @@index([videoId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============= AUTH MODELS =============

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============= ANALYTICS MODELS =============

model VideoAnalytics {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId         String
  date            DateTime
  viewsCount      Int      @default(0)
  uniqueViewers   Int      @default(0)
  watchTime       Int      @default(0) // total seconds watched
  avgWatchPercent Float    @default(0)
  likesCount      Int      @default(0)
  dislikesCount   Int      @default(0)
  commentsCount   Int      @default(0)
  shareCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([videoId, date])
  @@index([videoId])
  @@index([date])
}

model UserAnalytics {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  date            DateTime
  videosWatched   Int      @default(0)
  watchTime       Int      @default(0)
  videosUploaded  Int      @default(0)
  engagementScore Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([userId, date])
  @@index([userId])
  @@index([date])
}
