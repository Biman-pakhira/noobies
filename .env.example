# DATABASE
DATABASE_URL="mongodb://admin:password@localhost:27017/video_platform?authSource=admin"

# REDIS (used for sessions, caching, and job queue)
REDIS_URL="redis://localhost:6379"

# API SERVER
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="info"

# JWT AUTHENTICATION
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# FRONTEND
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_CDN_URL="http://localhost:3002"

# VIDEO PROCESSING (FFmpeg)
FFMPEG_PATH="/usr/bin/ffmpeg"
FFMPEG_OUTPUT_DIR="/tmp/video-processing"
MAX_VIDEO_SIZE="10737418240"  # 10GB in bytes

# VIDEO STORAGE - Choose CloudFlare R2 OR AWS S3

# CloudFlare R2 (Recommended for cost)
R2_ACCOUNT_ID="your-cloudflare-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="video-platform-videos"
R2_REGION="us-east-1"

# AWS S3 (Alternative to R2)
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_S3_BUCKET="video-platform-videos"
# AWS_REGION="us-east-1"

# CDN (for delivering videos)
CDN_URL="https://your-cdn.example.com"
BUNNY_API_KEY="your-bunny-api-key"

# SEARCH & ANALYTICS
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_USERNAME="elastic"
ELASTICSEARCH_PASSWORD="changeme"

CLICKHOUSE_HOST="localhost"
CLICKHOUSE_PORT="8123"
CLICKHOUSE_DATABASE="video_events"
CLICKHOUSE_USERNAME="default"
CLICKHOUSE_PASSWORD=""

# AI RECOMMENDATION SERVICE
RECOMMENDER_URL="http://localhost:8000"
RECOMMENDER_API_KEY="your-recommender-api-key"
